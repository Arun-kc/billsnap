# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/billsnap

# Auth — static bearer tokens (one per user, V1)
AUTH_TOKEN_OWNER=change-me-long-random-string-owner
AUTH_TOKEN_ADMIN=change-me-long-random-string-admin

# OCR — Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Storage — S3-compatible (Supabase Storage or Cloudflare R2)
STORAGE_BUCKET=billsnap-storage
STORAGE_ENDPOINT_URL=https://<account>.supabase.co/storage/v1/s3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1

# Signed URL expiry (seconds)
SIGNED_URL_TTL=900

# OCR worker
OCR_WORKER_POLL_INTERVAL=3       # seconds between polls
OCR_CONFIDENCE_THRESHOLD=0.70    # below this → Sonnet fallback
OCR_STUCK_JOB_TIMEOUT=300        # seconds before a 'processing' job is reset

# App
APP_ENV=development
LOG_LEVEL=INFO
