evals/ocr_benchmark/sample_bills/
evals/ocr_benchmark/results/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
.pytest_cache/

# Node
node_modules/
.next/
dist/
.turbo/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

# Claude Code — local project settings and worktrees
.claude/
.claudeignore

# Python — type checker and linter caches
.mypy_cache/
.ruff_cache/

# Test coverage artifacts
.coverage
htmlcov/

# Logs
*.log
